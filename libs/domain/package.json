{
  "name": "@one-kilo/domain",
  "version": "0.1.0",
  "dependencies": {
    "@effect/auth-workos": "workspace:*",
    "@one-kilo/lib": "workspace:*",
    "effect": "^3.21.2"
  },
  "exports": {
    "./*": "./dist/src/*.js",
    "./internal/*": null
  },
  "private": true,
  "scripts": {
    "build": "tsc --build tsconfig.src.json",
    "clean": "rm -rf .turbo dist",
    "test": "vitest",
    "test:once": "vitest run",
    "typecheck": "tsc --build && tsc --project tsconfig.test.json --noEmit"
  },
  "type": "module"
}
