{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "plugins": ["typescript", "import", "oxc", "eslint", "unicorn", "node"],
  "jsPlugins": ["@effect/oxc/oxlint"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error"
  },
  "rules": {
    "one-kilo/no-import-from-barrel-package": ["error", {
      "packageNames": [
        "effect",
        "@effect/experimental",
        "@effect/platform",
        "@effect/platform-node",
        "@effect/sql"
      ]
    }],
    "typescript/consistent-type-imports": ["error", { "fixStyle": "inline-type-imports" }],
    "typescript/no-import-type-side-effects": "error",
    "import/no-duplicates": "error",
    "import/no-self-import": "error",
    "import/no-empty-named-blocks": "error",
    "eslint/no-var": "error",
    "eslint/no-useless-constructor": "error",
    "eslint/no-unneeded-ternary": "error",
    "eslint/no-useless-concat": "error",
    "unicorn/no-abusive-eslint-disable": "error",
    "oxc/misrefactored-assign-op": "error",
    "eslint/no-underscore-dangle": "off",
    "import/no-unassigned-import": "off",
    "unicorn/no-array-sort": "off",
    "typescript/no-unused-vars": ["error", {
      "argsIgnorePattern": "^_",
      "varsIgnorePattern": "^_"
    }],
    "eslint/no-unused-vars": "off",
    "typescript/no-explicit-any": "off",
    "typescript/no-empty-interface": "off",
    "typescript/no-empty-object-type": "off",
    "typescript/ban-ts-comment": "off",
    "typescript/no-namespace": "off",
    "typescript/no-non-null-assertion": "off",
    "typescript/no-unsafe-function-type": "off",
    "typescript/no-confusing-non-null-assertion": "off",
    "eslint/no-shadow": "off",
    "eslint/require-yield": "off",
    "eslint/no-fallthrough": "off",
    "eslint/no-await-in-loop": "off",
    "unicorn/no-new-array": "off",
    "unicorn/consistent-function-scoping": "off"
  },
  "ignorePatterns": [
    "**/dist",
    "**/generated",
    "**/.next",
    "**/.turbo",
    "**/node_modules",
    "**/*.tsbuildinfo"
  ],
  "overrides": [
    {
      "files": ["apps/web/**/*.{ts,tsx,js,jsx}"],
      "plugins": ["react", "jsx-a11y", "nextjs"],
      "rules": {
        "nextjs/no-html-link-for-pages": "error",
        "nextjs/no-img-element": "error",
        "nextjs/no-sync-scripts": "error",
        "nextjs/no-page-custom-font": "error",
        "nextjs/google-font-display": "error",
        "nextjs/google-font-preconnect": "error",
        "react/rules-of-hooks": "error",
        "react/exhaustive-deps": "warn",
        "react/no-unescaped-entities": "off",
        "react/react-in-jsx-scope": "off",
        "react/jsx-key": "error",
        "react/jsx-no-target-blank": "error"
      }
    },
    {
      "files": ["**/test/**", "**/*.test.ts", "scripts/**"],
      "rules": {
        "eslint/no-console": "off"
      }
    }
  ]
}
