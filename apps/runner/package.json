{
  "name": "@one-kilo/runner",
  "version": "0.1.0",
  "dependencies": {
    "@effect/auth-workos": "workspace:*",
    "@effect/cluster": "^0.58.1",
    "@effect/platform-node": "^0.106.0",
    "@effect/workflow": "^0.18.0",
    "@one-kilo/core": "workspace:*",
    "@one-kilo/sql": "workspace:*",
    "@one-kilo/workflow": "workspace:*",
    "effect": "^3.21.2"
  },
  "private": true,
  "scripts": {
    "build": "tsc --build tsconfig.src.json",
    "clean": "rm -rf .turbo dist",
    "dev": "tsc --build tsconfig.src.json --watch --preserveWatchOutput > /dev/null 2>&1 & node --env-file=.env.local --enable-source-maps --watch dist/src/main.js",
    "start": "node --env-file=.env.local --enable-source-maps dist/src/main.js",
    "typecheck": "tsc --build tsconfig.src.json"
  },
  "type": "module"
}
