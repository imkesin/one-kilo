# Runner environment — copy to .env.local and adjust as needed

# Cluster runner address (advertised to other nodes via DB)
# RUNNER_HOST=localhost
# RUNNER_PORT=12000

# PostgreSQL — defaults match libs/sql/src/configs/Defaults.ts
# POSTGRES_HOST=localhost
# POSTGRES_PORT=20000
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=one_kilo_local
