{
  "name": "@one-kilo/server",
  "version": "0.1.0",
  "dependencies": {
    "@effect/auth-workos": "workspace:*",
    "@effect/cluster": "^0.58.1",
    "@effect/experimental": "^0.60.0",
    "@effect/platform": "^0.96.0",
    "@effect/platform-node": "^0.106.0",
    "@effect/sql": "^0.51.0",
    "@effect/sql-pg": "^0.52.1",
    "@effect/workflow": "^0.18.0",
    "@one-kilo/core": "workspace:*",
    "@one-kilo/domain": "workspace:*",
    "@one-kilo/lib": "workspace:*",
    "@one-kilo/server-api": "workspace:*",
    "@one-kilo/sql": "workspace:*",
    "@one-kilo/telemetry": "workspace:*",
    "effect": "^3.21.2",
    "jose": "^6.2.2"
  },
  "keywords": [],
  "license": "ISC",
  "private": true,
  "scripts": {
    "build": "tsc --build tsconfig.src.json",
    "clean": "rm -rf .turbo dist",
    "dev": "tsc --build tsconfig.src.json --watch --preserveWatchOutput > /dev/null 2>&1 & node --env-file=.env.local --enable-source-maps --watch dist/src/dev.js",
    "docker:build": "docker build --file Dockerfile --tag one-kilo-server ../..",
    "lint": "eslint .",
    "node:base": "node --env-file=.env.local --enable-source-maps",
    "start": "pnpm node:base dist/src/main.js",
    "test": "vitest",
    "test:integration": "vitest --config ./vitest.integration.config.ts",
    "test:once": "vitest run",
    "typecheck": "tsc --build tsconfig.src.json && tsc --project tsconfig.test.json --noEmit"
  },
  "type": "module"
}
