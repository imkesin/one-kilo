{
  "name": "@effect/auth-workos",
  "version": "0.1.0",
  "devDependencies": {
    "@effect/platform": "^0.96.0",
    "@effect/platform-node": "^0.106.0",
    "effect": "^3.21.0",
    "jose": "^6.2.2"
  },
  "exports": {
    "./*": {
      "types": "./dist/src/*.d.ts",
      "default": "./dist/src/*.js"
    },
    "./internal/*": null
  },
  "peerDependencies": {
    "@effect/platform": "^0.96.0",
    "effect": "^3.21.0",
    "jose": "^6.2.2"
  },
  "scripts": {
    "build": "tsc --build tsconfig.src.json",
    "clean": "rm -rf .turbo dist",
    "lint": "eslint .",
    "test": "vitest",
    "test:integration": "vitest --config ./vitest.integration.config.ts",
    "test:once": "vitest run",
    "typecheck": "tsc --build"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "libs/*",
    "packages/*"
  ]
}
