{
  "devDependencies": {
    "@effect/language-service": "latest",
    "@effect/oxc": "workspace:*",
    "@effect/vitest": "latest",
    "@types/node": "^25.9.3",
    "dprint": "^0.54.0",
    "oxlint": "1.42.0",
    "turbo": "^2.9.14",
    "typescript": "^6.0.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": "26"
  },
  "packageManager": "pnpm@11.1.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "clean": "turbo clean && rm -rf .turbo",
    "dev": "turbo watch dev",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "lint": "oxlint && dprint check",
    "lint:fix": "oxlint --fix && dprint fmt",
    "start": "turbo start",
    "test:once": "turbo test:once",
    "typecheck": "turbo typecheck"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "infra/*",
    "libs/*",
    "packages/*",
    "scripts/*"
  ]
}
