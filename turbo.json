{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".output/**",
        "dist/**"
      ]
    },
    "clean": {
      "cache": false,
      "dependsOn": [
        "^clean"
      ],
      "outputs": [
        ".output/**",
        "dist/**",
        ".turbo/**",
        "node_modules/.cache/**"
      ]
    },
    "dev": {
      "cache": false
    },
    "start": {
      "cache": false,
      "dependsOn": [
        "^build"
      ]
    },
    "test:once": {
      "cache": false,
      "dependsOn": [
        "^build",
        "^test:once",
        "^typecheck"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^build",
        "^typecheck"
      ]
    }
  }
}
